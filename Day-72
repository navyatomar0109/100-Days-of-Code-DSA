    char s[1000];
    int visited[26] = {0};   // For 'a' to 'z'

    // Input string
    scanf("%s", s);

    // Traverse string
    for(int i = 0; s[i] != '\0'; i++) {
        int index = s[i] - 'a';

        // If already seen → first repeated character
        if(visited[index] == 1) {
            printf("%c", s[i]);
            return 0;
        }

        // Mark as visited
        visited[index] = 1;
    }

    // No repeated character
    printf("-1");

    return 0;
