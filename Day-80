#include <stdio.h>

#define INF 1000000000  // A large value representing infinity

int main() {
    int n;
    scanf("%d", &n);

    int dist[n][n];

    // 🔹 Input and preprocessing
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &dist[i][j]);

            if (dist[i][j] == -1) {
                dist[i][j] = INF;  // Replace -1 with INF
            }
        }
    }

    // 🔹 Floyd-Warshall Algorithm
    for (int k = 0; k < n; k++) {          // Intermediate vertex
        for (int i = 0; i < n; i++) {      // Source
            for (int j = 0; j < n; j++) {  // Destination
                if (dist[i][k] + dist[k][j] < dist[i][j]) {
                    dist[i][j] = dist[i][k] + dist[k][j];
                }
            }
        }
    }

    // 🔹 Convert INF back to -1 and print result
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            if (dist[i][j] == INF)
                printf("-1 ");
            else
                printf("%d ", dist[i][j]);
        }
        printf("\n");
    }

    return 0;
}
