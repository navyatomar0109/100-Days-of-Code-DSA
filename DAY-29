#include <stdio.h>
#include <stdlib.h>

struct Node {
    int data;
    struct Node* next;
};

struct Node* createNode(int value) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = value;
    newNode->next = NULL;
    return newNode;
}

int main() {
    int n, k, val, i;
    struct Node *head = NULL, *temp = NULL, *last = NULL;

    scanf("%d", &n);

    // Create linked list
    for(i = 0; i < n; i++) {
        scanf("%d", &val);
        struct Node* newNode = createNode(val);

        if(head == NULL) {
            head = newNode;
            temp = head;
        } else {
            temp->next = newNode;
            temp = newNode;
        }
    }

    scanf("%d", &k);

    // Find last node and length
    last = head;
    int length = 1;
    while(last->next != NULL) {
        last = last->next;
        length++;
    }

    k = k % length;

    if(k == 0) {
        temp = head;
        while(temp != NULL) {
            printf("%d ", temp->data);
            temp = temp->next;
        }
        return 0;
    }

    // Make circular
    last->next = head;

    int steps = length - k;
    temp = head;

    for(i = 1; i < steps; i++)
        temp = temp->next;

    // New head
    head = temp->next;
    temp->next = NULL;

    // Print rotated list
    temp = head;
    while(temp != NULL) {
        printf("%d ", temp->data);
        temp = temp->next;
    }

    return 0;
}
