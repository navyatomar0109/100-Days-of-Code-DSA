#include <stdio.h>

#define MAX 1000

// Queue implementation using array
int queue[MAX];
int front = 0, rear = -1;

// Stack implementation using array
int stack[MAX];
int top = -1;

// Enqueue operation
void enqueue(int value) {
    queue[++rear] = value;
}

// Dequeue operation
int dequeue() {
    return queue[front++];
}

// Check if queue is empty
int isQueueEmpty() {
    return front > rear;
}

// Push into stack
void push(int value) {
    stack[++top] = value;
}

// Pop from stack
int pop() {
    return stack[top--];
}

// Check if stack is empty
int isStackEmpty() {
    return top == -1;
}

int main() {
    int N;
    scanf("%d", &N);

    // Input queue elements
    for (int i = 0; i < N; i++) {
        int x;
        scanf("%d", &x);
        enqueue(x);
    }

    // Step 1: Move queue elements into stack
    while (!isQueueEmpty()) {
        push(dequeue());
    }

    // Reset queue to refill it
    front = 0;
    rear = -1;

    // Step 2: Move stack elements back into queue
    while (!isStackEmpty()) {
        enqueue(pop());
    }

    // Print reversed queue
    for (int i = front; i <= rear; i++) {
        printf("%d ", queue[i]);
    }

    return 0;
}
