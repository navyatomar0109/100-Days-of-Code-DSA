#include <stdio.h>

int max(int a, int b) {
    return (a > b) ? a : b;
}

// Check if allocation is possible with given max limit
int isPossible(int arr[], int n, int m, int maxPages) {
    int students = 1;
    int currentSum = 0;

    for (int i = 0; i < n; i++) {
        if (arr[i] > maxPages)
            return 0; // single book exceeds limit

        if (currentSum + arr[i] > maxPages) {
            students++;
            currentSum = arr[i];

            if (students > m)
                return 0;
        } else {
            currentSum += arr[i];
        }
    }

    return 1;
}

int allocateBooks(int arr[], int n, int m) {
    if (m > n)
        return -1; // not possible

    int low = arr[0], high = 0;

    for (int i = 0; i < n; i++) {
        high += arr[i];
        if (arr[i] > low)
            low = arr[i];
    }

    int result = high;

    while (low <= high) {
        int mid = (low + high) / 2;

        if (isPossible(arr, n, m, mid)) {
            result = mid;
            high = mid - 1;  // try smaller maximum
        } else {
            low = mid + 1;   // increase limit
        }
    }

    return result;
}

int main() {
    int n, m;
    scanf("%d %d", &n, &m);

    int arr[n];

    for (int i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    printf("%d\n", allocateBooks(arr, n, m));

    return 0;
}
