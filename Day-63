#include <stdio.h>

#define MAX 100

int visited[MAX];
int adj[MAX][MAX];
int size[MAX];   // stores number of adjacent vertices for each node

// DFS function
void dfs(int v) {
    visited[v] = 1;
    printf("%d ", v);

    for (int i = 0; i < size[v]; i++) {
        int next = adj[v][i];
        if (!visited[next]) {
            dfs(next);
        }
    }
}

int main() {
    int n, s;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    // Input adjacency list
    printf("Enter adjacency list:\n");
    for (int i = 0; i < n; i++) {
        printf("Enter number of adjacent vertices for %d: ", i);
        scanf("%d", &size[i]);

        printf("Enter adjacent vertices of %d: ", i);
        for (int j = 0; j < size[i]; j++) {
            scanf("%d", &adj[i][j]);
        }
    }

    printf("Enter starting vertex: ");
    scanf("%d", &s);

    // Initialize visited array
    for (int i = 0; i < n; i++) {
        visited[i] = 0;
    }

    printf("DFS Traversal: ");
    dfs(s);

    return 0;

}
