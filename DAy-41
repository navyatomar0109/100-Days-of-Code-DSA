// Function to find maximum of two numbers
int max(int a, int b) {
    return (a > b) ? a : b;
}

// Function to calculate minimum intervals
int leastInterval(char tasks[], int tasksSize, int n) {
    int freq[26] = {0};

    // Count frequency of each task
    for (int i = 0; i < tasksSize; i++) {
        freq[tasks[i] - 'A']++;
    }

    // Find maximum frequency
    int maxFreq = 0;
    for (int i = 0; i < 26; i++) {
        if (freq[i] > maxFreq)
            maxFreq = freq[i];
    }

    // Count how many tasks have max frequency
    int maxCount = 0;
    for (int i = 0; i < 26; i++) {
        if (freq[i] == maxFreq)
            maxCount++;
    }

    // Apply formula
    int partCount = maxFreq - 1;
    int partLength = n + 1;
    int result = partCount * partLength + maxCount;

    return max(tasksSize, result);
}

// Main function
int main() {
    char tasks[] = {'A','A','A','B','B','B'};
    int n = 2;
    int tasksSize = sizeof(tasks) / sizeof(tasks[0]);

    printf("Minimum intervals required: %d\n", leastInterval(tasks, tasksSize, n));

    return 0;
}
