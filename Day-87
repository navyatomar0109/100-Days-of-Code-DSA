#include <stdio.h>

int integerSqrt(int n) {
    if (n < 2)
        return n;

    int left = 0, right = n, ans = 0;

    while (left <= right) {
        int mid = left + (right - left) / 2;

        // To avoid overflow, use division instead of mid*mid
        if (mid == n / mid) {
            return mid;
        } else if (mid < n / mid) {
            ans = mid;          // possible answer
            left = mid + 1;
        } else {
            right = mid - 1;
        }
    }

    return ans;
}

int main() {
    int n;
    scanf("%d", &n);

    printf("%d\n", integerSqrt(n));

    return 0;
}
