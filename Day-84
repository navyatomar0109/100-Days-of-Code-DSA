#include <stdio.h>

int findPeakElement(int nums[], int n) {
    int low = 0, high = n - 1;

    while (low < high) {
        int mid = (low + high) / 2;

        if (nums[mid] < nums[mid + 1])
            low = mid + 1;   // Peak is on right side
        else
            high = mid;      // Peak is on left side (including mid)
    }

    return low;  // or high (both same)
}

int main() {
    int n;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int nums[n];

    printf("Enter elements:\n");
    for (int i = 0; i < n; i++) {
        scanf("%d", &nums[i]);
    }

    int peakIndex = findPeakElement(nums, n);

    printf("Peak element index: %d\n", peakIndex);
    printf("Peak element value: %d\n", nums[peakIndex]);

    return 0;
}
