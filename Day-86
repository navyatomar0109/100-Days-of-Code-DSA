#include <stdio.h>

// Function to calculate total hours needed for a given speed k
long long totalHours(int piles[], int n, int k) {
    long long hours = 0;
    for(int i = 0; i < n; i++) {
        // ceil(piles[i] / k)
        hours += (piles[i] + k - 1) / k;
    }
    return hours;
}

// Function to find minimum k
int minEatingSpeed(int piles[], int n, int h) {
    int left = 1;
    
    // Find max element
    int right = piles[0];
    for(int i = 1; i < n; i++) {
        if(piles[i] > right)
            right = piles[i];
    }

    int ans = right;

    while(left <= right) {
        int mid = (left + right) / 2;

        if(totalHours(piles, n, mid) <= h) {
            ans = mid;          // possible answer
            right = mid - 1;    // try smaller k
        } else {
            left = mid + 1;     // increase k
        }
    }

    return ans;
}

int main() {
    int n, h;

    printf("Enter number of piles: ");
    scanf("%d", &n);

    int piles[n];

    printf("Enter bananas in each pile:\n");
    for(int i = 0; i < n; i++) {
        scanf("%d", &piles[i]);
    }

    printf("Enter hours (h): ");
    scanf("%d", &h);

    int result = minEatingSpeed(piles, n, h);

    printf("Minimum eating speed k = %d\n", result);

    return 0;
}
