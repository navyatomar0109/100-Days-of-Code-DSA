#include <stdio.h>
#include <stdlib.h>
#include <limits.h>
#include <stdbool.h>

int min(int a, int b) {
    return a < b ? a : b;
}

// Manhattan distance
int dist(int x1, int y1, int x2, int y2) {
    return abs(x1 - x2) + abs(y1 - y2);
}

int minCostConnectPoints(int points[][2], int n) {
    int minDist[n];
    bool visited[n];

    // Initialize
    for (int i = 0; i < n; i++) {
        minDist[i] = INT_MAX;
        visited[i] = false;
    }

    minDist[0] = 0;
    int result = 0;

    for (int i = 0; i < n; i++) {
        int u = -1;

        // Pick minimum distance node not yet visited
        for (int j = 0; j < n; j++) {
            if (!visited[j] && (u == -1 || minDist[j] < minDist[u])) {
                u = j;
            }
        }

        visited[u] = true;
        result += minDist[u];

        // Update distances
        for (int v = 0; v < n; v++) {
            if (!visited[v]) {
                int d = dist(points[u][0], points[u][1],
                             points[v][0], points[v][1]);
                minDist[v] = min(minDist[v], d);
            }
        }
    }

    return result;
}

int main() {
    int points[][2] = {{0,0},{2,2},{3,10},{5,2},{7,0}};
    int n = 5;

    printf("%d\n", minCostConnectPoints(points, n));

    return 0;
}
