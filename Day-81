#include <stdio.h>

int binarySearch(int nums[], int n, int target) {
    int left = 0;
    int right = n - 1;

    while (left <= right) {
        int mid = left + (right - left) / 2;

        if (nums[mid] == target) {
            return mid;
        }
        else if (nums[mid] < target) {
            left = mid + 1;
        }
        else {
            right = mid - 1;
        }
    }

    return -1;
}

int main() {
    int n, target;

    // Input size
    scanf("%d", &n);

    int nums[n];

    // Input sorted array
    for (int i = 0; i < n; i++) {
        scanf("%d", &nums[i]);
    }

    // Input target
    scanf("%d", &target);

    // Function call
    int result = binarySearch(nums, n, target);

    // Output result
    printf("%d", result);

    return 0;
}
