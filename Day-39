#include <stdio.h>
#include <stdlib.h>

#define MAX 100001

typedef struct Node {
    int val;
    struct Node* next;
} Node;

// Add node to bucket
void add(Node** bucket, int val) {
    Node* newNode = (Node*)malloc(sizeof(Node));
    newNode->val = val;
    newNode->next = *bucket;
    *bucket = newNode;
}

void topKFrequent(int nums[], int n, int k) {
    int freq[MAX] = {0};

    // Step 1: Count frequency
    for (int i = 0; i < n; i++) {
        freq[nums[i] + 10000]++;  // shift for negative values
    }

    // Step 2: Create buckets
    Node* bucket[n + 1];
    for (int i = 0; i <= n; i++) bucket[i] = NULL;

    // Step 3: Fill buckets
    for (int i = 0; i < MAX; i++) {
        if (freq[i] > 0) {
            add(&bucket[freq[i]], i - 10000);
        }
    }

    // Step 4: Collect top k
    int count = 0;
    for (int i = n; i >= 0 && count < k; i--) {
        Node* temp = bucket[i];
        while (temp && count < k) {
            printf("%d ", temp->val);
            temp = temp->next;
            count++;
        }
    }
}

int main() {
    int nums[] = {1,1,1,2,2,3};
    int n = 6, k = 2;

    topKFrequent(nums, n, k);

    return 0;
}
