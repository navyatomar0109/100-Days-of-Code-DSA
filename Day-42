typedef struct {
    int arr[MAX];
    int size;
} MinHeap;

void minHeapifyUp(MinHeap* h, int i) {
    while (i > 0) {
        int parent = (i - 1) / 2;
        if (h->arr[parent] > h->arr[i]) {
            int temp = h->arr[parent];
            h->arr[parent] = h->arr[i];
            h->arr[i] = temp;
            i = parent;
        } else {
            break;
        }
    }
}

void minHeapifyDown(MinHeap* h, int i) {
    while (1) {
        int smallest = i;
        int left = 2 * i + 1;
        int right = 2 * i + 2;

        if (left < h->size && h->arr[left] < h->arr[smallest])
            smallest = left;
        if (right < h->size && h->arr[right] < h->arr[smallest])
            smallest = right;

        if (smallest != i) {
            int temp = h->arr[i];
            h->arr[i] = h->arr[smallest];
            h->arr[smallest] = temp;
            i = smallest;
        } else {
            break;
        }
    }
}

void minInsert(MinHeap* h, int val) {
    h->arr[h->size] = val;
    h->size++;
    minHeapifyUp(h, h->size - 1);
}

int minExtract(MinHeap* h) {
    int root = h->arr[0];
    h->arr[0] = h->arr[h->size - 1];
    h->size--;
    minHeapifyDown(h, 0);
    return root;
}

int minTop(MinHeap* h) {
    return h->arr[0];
}

// -------- MedianFinder --------
typedef struct {
    MaxHeap left;   // smaller half
    MinHeap right;  // larger half
} MedianFinder;

MedianFinder* medianFinderCreate() {
    MedianFinder* obj = (MedianFinder*)malloc(sizeof(MedianFinder));
    obj->left.size = 0;
    obj->right.size = 0;
    return obj;
}

void addNum(MedianFinder* obj, int num) {
    // Step 1: Add to max heap
    if (obj->left.size == 0 || num <= maxTop(&obj->left)) {
        maxInsert(&obj->left, num);
    } else {
        minInsert(&obj->right, num);
    }

    // Step 2: Balance heaps
    if (obj->left.size > obj->right.size + 1) {
        minInsert(&obj->right, maxExtract(&obj->left));
    } else if (obj->right.size > obj->left.size) {
        maxInsert(&obj->left, minExtract(&obj->right));
    }
}

double findMedian(MedianFinder* obj) {
    if (obj->left.size > obj->right.size) {
        return (double)maxTop(&obj->left);
    } else {
        return ((double)maxTop(&obj->left) + (double)minTop(&obj->right)) / 2.0;
    }
}

void medianFinderFree(MedianFinder* obj) {
    free(obj);
}

// -------- Main for Testing --------
int main() {
    MedianFinder* mf = medianFinderCreate();

    addNum(mf, 1);
    addNum(mf, 2);
    printf("Median: %.1f\n", findMedian(mf)); // 1.5

    addNum(mf, 3);
    printf("Median: %.1f\n", findMedian(mf)); // 2.0

    medianFinderFree(mf);
    return 0;
}
