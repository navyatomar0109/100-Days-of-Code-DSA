#include <stdio.h>

#define MAX 100000

int deque[MAX]; // stores indices
int front = 0, rear = -1;

// Check if deque is empty
int isEmpty() {
    return front > rear;
}

// Remove front
void popFront() {
    front++;
}

// Remove rear
void popBack() {
    rear--;
}

// Add to rear
void pushBack(int x) {
    deque[++rear] = x;
}

void slidingWindowMax(int nums[], int n, int k) {
    int result[MAX];
    int idx = 0;

    for (int i = 0; i < n; i++) {

        // Remove elements out of window
        if (!isEmpty() && deque[front] <= i - k)
            popFront();

        // Remove smaller elements from back
        while (!isEmpty() && nums[deque[rear]] < nums[i])
            popBack();

        // Add current index
        pushBack(i);

        // Store result
        if (i >= k - 1)
            result[idx++] = nums[deque[front]];
    }

    // Print result
    for (int i = 0; i < idx; i++)
        printf("%d ", result[i]);
}

int main() {
    int nums[] = {1,3,-1,-3,5,3,6,7};
    int n = 8;
    int k = 3;

    slidingWindowMax(nums, n, k);

    return 0;
}
