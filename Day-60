#include <stdio.h>

int isMinHeap(int arr[], int n) {
    // Check all parent nodes
    for (int i = 0; i <= (n - 2) / 2; i++) {
        int left = 2 * i + 1;
        int right = 2 * i + 2;

        // Check left child
        if (left < n && arr[i] > arr[left]) {
            return 0; // Not Min-Heap
        }

        // Check right child
        if (right < n && arr[i] > arr[right]) {
            return 0; // Not Min-Heap
        }
    }
    return 1; // Valid Min-Heap
}

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    if (isMinHeap(arr, n)) {
        printf("YES\n");
    } else {
        printf("NO\n");
    }

    return 0;
}
