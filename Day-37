#include <stdio.h>
#include <string.h>

#define MAX 100

int pq[MAX];
int size = 0;

// Function to insert element
void insert(int x) {
    int i;
    
    // Find position to insert
    for (i = size - 1; i >= 0 && pq[i] > x; i--) {
        pq[i + 1] = pq[i];  // shift right
    }
    
    pq[i + 1] = x;
    size++;
}

// Function to delete (remove smallest)
int delete() {
    if (size == 0) {
        return -1;
    }
    
    int val = pq[0];
    
    // shift left
    for (int i = 1; i < size; i++) {
        pq[i - 1] = pq[i];
    }
    
    size--;
    return val;
}

// Function to peek (smallest element)
int peek() {
    if (size == 0) {
        return -1;
    }
    return pq[0];
}

