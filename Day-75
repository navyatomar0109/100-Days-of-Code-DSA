#include <stdio.h>

int maxLen(int arr[], int n) {
    int sum = 0, max_len = 0;

    // Using simple array as hashmap (for small constraints)
    // Initialize with -1
    int hash[1000];
    for(int i = 0; i < 1000; i++)
        hash[i] = -2; // -2 means not visited

    for(int i = 0; i < n; i++) {
        sum += arr[i];

        // Case 1: sum becomes 0
        if(sum == 0) {
            max_len = i + 1;
        }

        // Case 2: sum seen before
        if(hash[sum + 500] != -2) {
            int prev_index = hash[sum + 500];
            int length = i - prev_index;
            if(length > max_len)
                max_len = length;
        } else {
            hash[sum + 500] = i;
        }
    }

    return max_len;
}

int main() {
    int arr[] = {15, -2, 2, -8, 1, 7, 10, 23};
    int n = sizeof(arr) / sizeof(arr[0]);

    printf("%d", maxLen(arr, n));

    return 0;
}
