#include <stdio.h>
#include <string.h>
#include <stdbool.h>

bool isValid(char *s) {

    char stack[10000];
    int top = -1;

    for(int i = 0; s[i] != '\0'; i++) {

        char ch = s[i];

        // Push opening brackets
        if(ch == '(' || ch == '{' || ch == '[') {
            stack[++top] = ch;
        }
        else {

            if(top == -1)
                return false;

            char popped = stack[top--];

            if((ch == ')' && popped != '(') ||
               (ch == '}' && popped != '{') ||
               (ch == ']' && popped != '['))
                return false;
        }
    }

    return (top == -1);
}

int main() {

    char s[10000];

    scanf("%s", s);

    if(isValid(s))
        printf("true");
    else
        printf("false");

    return 0;
}
