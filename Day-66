#include <stdio.h>
#include <stdlib.h>

#define MAX 100

int graph[MAX][MAX];   // Adjacency matrix
int visited[MAX];
int recStack[MAX];
int n;

// DFS function to detect cycle
int dfs(int node) {
    visited[node] = 1;
    recStack[node] = 1;

    for (int i = 0; i < n; i++) {
        if (graph[node][i]) {
            // If not visited → recurse
            if (!visited[i] && dfs(i))
                return 1;

            // If in recursion stack → cycle found
            else if (recStack[i])
                return 1;
        }
    }

    recStack[node] = 0; // remove from recursion stack
    return 0;
}

// Function to check cycle
int hasCycle() {
    for (int i = 0; i < n; i++) {
        if (!visited[i]) {
            if (dfs(i))
                return 1;
        }
    }
    return 0;
}

