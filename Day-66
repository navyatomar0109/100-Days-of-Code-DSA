#include <stdio.h>
#include <stdlib.h>

#define MAX 2000

int **graph;
int *visited;
int *recStack;
int numCourses;

// DFS to detect cycle
int dfs(int node) {
    visited[node] = 1;
    recStack[node] = 1;

    for (int i = 0; i < numCourses; i++) {
        if (graph[node][i]) {
            if (!visited[i] && dfs(i))
                return 1;

            else if (recStack[i])
                return 1;
        }
    }

    recStack[node] = 0;
    return 0;
}

// Function to check if all courses can be finished
int canFinish(int numCourses, int prerequisites[][2], int size) {
    // Allocate adjacency matrix
    graph = (int **)malloc(numCourses * sizeof(int *));
    for (int i = 0; i < numCourses; i++) {
        graph[i] = (int *)calloc(numCourses, sizeof(int));
    }

    // Build graph (b → a)
    for (int i = 0; i < size; i++) {
        int a = prerequisites[i][0];
        int b = prerequisites[i][1];
        graph[b][a] = 1;
    }

    // Allocate visited arrays
    visited = (int *)calloc(numCourses, sizeof(int));
    recStack = (int *)calloc(numCourses, sizeof(int));

    // Check for cycle
    for (int i = 0; i < numCourses; i++) {
        if (!visited[i]) {
            if (dfs(i))
                return 0; // cycle found → cannot finish
        }
    }

    return 1; // no cycle → can finish
}
