#include <stdio.h>

#define MAX 100000

void dailyTemperatures(int temp[], int n) {
    int stack[MAX];   // stores indices
    int top = -1;

    int ans[MAX];

    // Initialize answer with 0
    for (int i = 0; i < n; i++)
        ans[i] = 0;

    for (int i = 0; i < n; i++) {

        // Resolve previous colder days
        while (top != -1 && temp[i] > temp[stack[top]]) {
            int idx = stack[top--];
            ans[idx] = i - idx;
        }

        // Push current index
        stack[++top] = i;
    }

    // Print result
    for (int i = 0; i < n; i++)
        printf("%d ", ans[i]);
}

int main() {
    int temp[] = {73,74,75,71,69,72,76,73};
    int n = 8;

    dailyTemperatures(temp, n);

    return 0;
}
