#include <stdio.h>

#define MAX 50

// DFS function
void floodFillDFS(int image[MAX][MAX], int rows, int cols, int r, int c, int originalColor, int newColor) {
    // Boundary check
    if (r < 0 || r >= rows || c < 0 || c >= cols)
        return;

    // If current cell is not the original color, stop
    if (image[r][c] != originalColor)
        return;

    // Change color
    image[r][c] = newColor;

    // Visit 4 directions
    floodFillDFS(image, rows, cols, r - 1, c, originalColor, newColor); // Up
    floodFillDFS(image, rows, cols, r + 1, c, originalColor, newColor); // Down
    floodFillDFS(image, rows, cols, r, c - 1, originalColor, newColor); // Left
    floodFillDFS(image, rows, cols, r, c + 1, originalColor, newColor); // Right
}

int main() {
    int image[MAX][MAX];
    int m, n;
    int sr, sc, color;

    printf("Enter number of rows and columns: ");
    scanf("%d %d", &m, &n);

    printf("Enter image matrix:\n");
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &image[i][j]);
        }
    }

    printf("Enter starting row, starting column, and new color: ");
    scanf("%d %d %d", &sr, &sc, &color);

    int originalColor = image[sr][sc];

    // If original color and new color are same, no need to fill
    if (originalColor != color) {
        floodFillDFS(image, m, n, sr, sc, originalColor, color);
    }

    printf("Modified Image after Flood Fill:\n");
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            printf("%d ", image[i][j]);
        }
        printf("\n");
    }

    return 0;
}
