#include <stdio.h>
#include <limits.h>
#include <string.h>

#define MAXN 15

int n;
int cost[MAXN][MAXN];
int dp[1 << MAXN][MAXN];

// Function to solve TSP
int tsp(int mask, int pos) {
    // If all cities visited, return cost to go back to start
    if (mask == (1 << n) - 1) {
        return cost[pos][0];
    }

    // If already computed
    if (dp[mask][pos] != -1) {
        return dp[mask][pos];
    }

    int ans = INT_MAX;

    // Try all cities
    for (int city = 0; city < n; city++) {
        // If city not visited
        if ((mask & (1 << city)) == 0) {
            int newAns = cost[pos][city] +
                         tsp(mask | (1 << city), city);

            if (newAns < ans) {
                ans = newAns;
            }
        }
    }

    return dp[mask][pos] = ans;
}

int main() {
    scanf("%d", &n);

    // Input cost matrix
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &cost[i][j]);
        }
    }

    // Initialize DP with -1
    memset(dp, -1, sizeof(dp));

    // Start from city 0, mask = 1 (only city 0 visited)
    int result = tsp(1, 0);

    printf("%d", result);

    return 0;
}
