#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>

#define MAX 100000

int stack[MAX], top = -1;

// Push to stack
void push(int x) {
    stack[++top] = x;
}

// Pop from stack
int pop() {
    return stack[top--];
}

// DFS for original graph (fill stack)
void dfs1(int u, bool visited[], int* adj[], int adjSize[]) {
    visited[u] = true;

    for (int i = 0; i < adjSize[u]; i++) {
        int v = adj[u][i];
        if (!visited[v]) {
            dfs1(v, visited, adj, adjSize);
        }
    }

    push(u);
}

// DFS for reversed graph
void dfs2(int u, bool visited[], int* revAdj[], int revSize[]) {
    visited[u] = true;

    for (int i = 0; i < revSize[u]; i++) {
        int v = revAdj[u][i];
        if (!visited[v]) {
            dfs2(v, visited, revAdj, revSize);
        }
    }
}

int countSCC(int V, int* adj[], int adjSize[], int* revAdj[], int revSize[]) {
    bool visited[MAX] = {false};

    // Step 1: Fill stack
    for (int i = 0; i < V; i++) {
        if (!visited[i]) {
            dfs1(i, visited, adj, adjSize);
        }
    }

    // Reset visited
    for (int i = 0; i < V; i++) {
        visited[i] = false;
    }

    int sccCount = 0;

    // Step 2 & 3
    while (top != -1) {
        int u = pop();

        if (!visited[u]) {
            dfs2(u, visited, revAdj, revSize);
            sccCount++;
        }
    }

    return sccCount;
}

int main() {
    int V, E;
    scanf("%d %d", &V, &E);

    int* adj[V];
    int* revAdj[V];
    int adjSize[V], revSize[V];

    // Initialize
    for (int i = 0; i < V; i++) {
        adj[i] = (int*)malloc(V * sizeof(int));
        revAdj[i] = (int*)malloc(V * sizeof(int));
        adjSize[i] = 0;
        revSize[i] = 0;
    }

    // Input edges
    for (int i = 0; i < E; i++) {
        int u, v;
        scanf("%d %d", &u, &v);

        adj[u][adjSize[u]++] = v;
        revAdj[v][revSize[v]++] = u; // reverse edge
    }

    printf("%d\n", countSCC(V, adj, adjSize, revAdj, revSize));

    return 0;
}
