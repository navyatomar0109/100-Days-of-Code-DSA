#include <stdio.h>
#include <string.h>

#define MAX 100

int pq[MAX];
int size = 0;

void insert(int x)
{
    if(size == MAX)
        return;

    pq[size] = x;
    size++;
}

int findMinIndex()
{
    if(size == 0)
        return -1;

    int min = 0;

    for(int i = 1; i < size; i++)
    {
        if(pq[i] < pq[min])
            min = i;
    }

    return min;
}

void deletePQ()
{
    if(size == 0)
    {
        printf("-1\n");
        return;
    }

    int minIndex = findMinIndex();
    int value = pq[minIndex];

    printf("%d\n", value);

    for(int i = minIndex; i < size - 1; i++)
        pq[i] = pq[i + 1];

    size--;
}

void peek()
{
    if(size == 0)
    {
        printf("-1\n");
        return;
    }

    int minIndex = findMinIndex();
    printf("%d\n", pq[minIndex]);
}

int main()
{
    int n, x;
    char op[10];

    scanf("%d", &n);

    for(int i = 0; i < n; i++)
    {
        scanf("%s", op);

        if(strcmp(op, "insert") == 0)
        {
            scanf("%d", &x);
            insert(x);
        }
        else if(strcmp(op, "delete") == 0)
        {
            deletePQ();
        }
        else if(strcmp(op, "peek") == 0)
        {
            peek();
        }
    }

    return 0;
}
