#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX 10000

int stack[MAX];
int top = -1;

void push(int val){
    stack[++top] = val;
}

int pop(){
    return stack[top--];
}

int evalRPN(char* tokens[], int n){

    for(int i = 0; i < n; i++){

        if(strcmp(tokens[i], "+") == 0){
            int b = pop();
            int a = pop();
            push(a + b);
        }
        else if(strcmp(tokens[i], "-") == 0){
            int b = pop();
            int a = pop();
            push(a - b);
        }
        else if(strcmp(tokens[i], "*") == 0){
            int b = pop();
            int a = pop();
            push(a * b);
        }
        else if(strcmp(tokens[i], "/") == 0){
            int b = pop();
            int a = pop();
            push(a / b);
        }
        else{
            push(atoi(tokens[i]));
        }
    }

    return pop();
}

int main(){

    char* tokens[] = {"2","1","+","3","*"};
    int n = 5;

    printf("%d", evalRPN(tokens, n));

    return 0;
}
