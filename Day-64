typedef struct {
    int x, y;
} Pair;

int orangesRotting(int** grid, int gridSize, int* gridColSize) {
    int rows = gridSize;
    int cols = gridColSize[0];
    
    Pair queue[200];
    int front = 0, rear = 0;
    
    int fresh = 0;
    int minutes = 0;
    
    // Step 1: Add all rotten oranges to queue, count fresh ones
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            if (grid[i][j] == 2) {
                queue[rear++] = (Pair){i, j};
            } else if (grid[i][j] == 1) {
                fresh++;
            }
        }
    }
    
    // If no fresh oranges
    if (fresh == 0) return 0;
    
    int dir[4][2] = {{-1,0},{1,0},{0,-1},{0,1}};
    
    // Step 2: BFS
    while (front < rear) {
        int size = rear - front;
        int rottenThisMinute = 0;
        
        for (int i = 0; i < size; i++) {
            Pair current = queue[front++];
            
            for (int d = 0; d < 4; d++) {
                int nx = current.x + dir[d][0];
                int ny = current.y + dir[d][1];
                
                if (nx >= 0 && nx < rows && ny >= 0 && ny < cols && grid[nx][ny] == 1) {
                    grid[nx][ny] = 2; // Make rotten
                    fresh--;
                    queue[rear++] = (Pair){nx, ny};
                    rottenThisMinute = 1;
                }
            }
        }
        
        if (rottenThisMinute)
            minutes++;
    }
    
    // If fresh oranges still remain
    return (fresh == 0) ? minutes : -1;
}
