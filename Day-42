#include <stdio.h>
#include <stdlib.h>

#define MAX 50000

// -------- Max Heap --------
typedef struct {
    int arr[MAX];
    int size;
} MaxHeap;

void maxHeapifyUp(MaxHeap* h, int i) {
    while (i > 0) {
        int parent = (i - 1) / 2;
        if (h->arr[parent] < h->arr[i]) {
            int temp = h->arr[parent];
            h->arr[parent] = h->arr[i];
            h->arr[i] = temp;
            i = parent;
        } else {
            break;
        }
    }
}

void maxHeapifyDown(MaxHeap* h, int i) {
    while (1) {
        int largest = i;
        int left = 2 * i + 1;
        int right = 2 * i + 2;

        if (left < h->size && h->arr[left] > h->arr[largest])
            largest = left;
        if (right < h->size && h->arr[right] > h->arr[largest])
            largest = right;

        if (largest != i) {
            int temp = h->arr[i];
            h->arr[i] = h->arr[largest];
            h->arr[largest] = temp;
            i = largest;
        } else {
            break;
        }
    }
}

void maxInsert(MaxHeap* h, int val) {
    h->arr[h->size] = val;
    h->size++;
    maxHeapifyUp(h, h->size - 1);
}

int maxExtract(MaxHeap* h) {
    int root = h->arr[0];
    h->arr[0] = h->arr[h->size - 1];
    h->size--;
    maxHeapifyDown(h, 0);
    return root;
}

int maxTop(MaxHeap* h) {
    return h->arr[0];
}

