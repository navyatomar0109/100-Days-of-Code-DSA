#include <stdio.h>
#include <string.h>
#include <stdlib.h>

#define MAX 26

// Queue
int queue[MAX];
int front = 0, rear = 0;

void enqueue(int x) {
    queue[rear++] = x;
}

int dequeue() {
    return queue[front++];
}

int isEmpty() {
    return front == rear;
}

char* alienOrder(char words[][100], int n) {
    static char result[MAX + 1];
    int adj[MAX][MAX] = {0};
    int indegree[MAX] = {0};
    int present[MAX] = {0};

    // Mark characters present
    for (int i = 0; i < n; i++) {
        for (int j = 0; words[i][j]; j++) {
            present[words[i][j] - 'a'] = 1;
        }
    }

    // Build graph
    for (int i = 0; i < n - 1; i++) {
        char *w1 = words[i];
        char *w2 = words[i + 1];
        int len1 = strlen(w1), len2 = strlen(w2);
        int found = 0;

        for (int j = 0; j < len1 && j < len2; j++) {
            if (w1[j] != w2[j]) {
                int u = w1[j] - 'a';
                int v = w2[j] - 'a';

                if (!adj[u][v]) {
                    adj[u][v] = 1;
                    indegree[v]++;
                }
                found = 1;
                break;
            }
        }

        // Invalid case: prefix issue
        if (!found && len1 > len2) {
            return "";
        }
    }

    // Initialize queue with indegree 0
    for (int i = 0; i < MAX; i++) {
        if (present[i] && indegree[i] == 0) {
            enqueue(i);
        }
    }

    int index = 0;

    // Kahn’s Algorithm
    while (!isEmpty()) {
        int u = dequeue();
        result[index++] = u + 'a';

        for (int v = 0; v < MAX; v++) {
            if (adj[u][v]) {
                indegree[v]--;
                if (indegree[v] == 0) {
                    enqueue(v);
                }
            }
        }
    }

    result[index] = '\0';

    // Check for cycle
    int totalChars = 0;
    for (int i = 0; i < MAX; i++) {
        if (present[i]) totalChars++;
    }

    if (index != totalChars) {
        return "";
    }

    return result;
}

// Driver code
int main() {
    int n;
    printf("Enter number of words: ");
    scanf("%d", &n);

    char words[n][100];
    printf("Enter words:\n");
    for (int i = 0; i < n; i++) {
        scanf("%s", words[i]);
    }

    char *order = alienOrder(words, n);

    if (strlen(order) == 0) {
        printf("Invalid ordering (cycle detected)\n");
    } else {
        printf("Alien Dictionary Order: %s\n", order);
    }

    return 0;
}
